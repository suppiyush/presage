{
  "packages": {
    "python": "3.12",
    "node": "22"
  },
  "phases": {
    "install": {
      "cmds": [
        "pip install -r backend/requirements.txt",
        "cd frontend && npm install"
      ]
    },
    "build": {
      "cmds": [
        "cd frontend && npm run build"
      ]
    }
  },
  "deploy": {
    "startCmd": "/app/.venv/bin/uvicorn backend.app.main:app --host 0.0.0.0 --port $PORT"
  }
}
