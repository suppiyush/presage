{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.12",
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        "python -m venv /app/.venv",
        "/app/.venv/bin/pip install -r /app/backend/requirements.txt",
        "cd frontend && npm install"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "cd frontend && npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "/app/.venv/bin/python -m uvicorn backend.app.main:app --host 0.0.0.0 --port $PORT"
  }
}
